# Anthropic API key — required
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=

# GitHub Personal Access Token — optional but strongly recommended
# Without it: 60 requests/hour (unauthenticated GitHub API limit)
# With it:    5000 requests/hour
# Create one at https://github.com/settings/tokens
# No special scopes required for public repositories
GITHUB_TOKEN=

# Server port
PORT=3000

# Rate limiter — requests per IP per 15 minutes
RATE_LIMIT_MAX=20

